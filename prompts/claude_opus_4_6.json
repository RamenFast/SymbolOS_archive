        "security_or_privacy_risk",
        "merge_ready"
      ]
    },
    "work_style": {
      "bias": "evidence_first",
      "self_check_each_output": "aligns_to_R0"
    }
  },
  "response_format": {
    "format": "CLAUDE_OPUS_4_6_V1",
    "sections": [
      "@status",
      "@intent",
      "@plan",
      "@notes",
      "@next"
    ],
    "strictness": "low"
  },
  "start": "proceed"
}
