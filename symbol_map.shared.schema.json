{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Symbol Map (Shared)",
    "description": "The canonical shared symbol map for SymbolOS, including symbol versioning.",
    "type": "object",
    "required": ["schema_version", "symbols"],
    "properties": {
        "schema_version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+$"
        },
        "symbols": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["symbol", "name", "meaning", "added"],
                "properties": {
                    "symbol": {"type": "string"},
                    "name": {"type": "string"},
                    "meaning": {"type": "string"},
                    "added": {
                        "type": "string",
                        "format": "date"
                    },
                    "evolution": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["date", "change", "reason", "mercer_id"],
                            "properties": {
                                "date": {"type": "string", "format": "date"},
                                "change": {"type": "string"},
                                "reason": {"type": "string"},
                                "mercer_id": {"type": "string"}
                            }
                        }
                    }
                }
            }
        }
    }
}
