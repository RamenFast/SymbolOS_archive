{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symbolos.local/schemas/memory_record.schema.json",
  "title": "MemoryRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "title", "summary", "scope", "provenance"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["fact", "preference", "plan", "story"] },
    "title": { "type": "string", "minLength": 1, "maxLength": 80 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 400 },
    "details": { "type": ["string", "null"], "maxLength": 4000 },
    "tags": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
    "scope": { "type": "string", "enum": ["private", "party", "dm", "public"], "default": "private" },
    "ttlSeconds": { "type": ["integer", "null"], "minimum": 60 },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "createdAt"],
      "properties": {
        "source": { "type": "string", "enum": ["user_manual", "assistant", "system"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "evidence": { "type": "array", "items": { "type": "string" }, "maxItems": 20 }
      }
    }
  }
}
