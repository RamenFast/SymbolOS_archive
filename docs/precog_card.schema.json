{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symbolos.local/schemas/precog_card.schema.json",
  "title": "PrecogCard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "mode",
    "headline",
    "why",
    "ready",
    "actions",
    "privacy",
    "cost",
    "createdAt"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["prefetch", "suggest", "act"] },
    "headline": { "type": "string", "minLength": 1, "maxLength": 200 },
    "why": { "type": "string", "minLength": 1, "maxLength": 500 },
    "ready": { "type": "string", "minLength": 1, "maxLength": 500 },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "kind"],
        "properties": {
          "label": { "type": "string", "minLength": 1, "maxLength": 60 },
          "kind": { "type": "string", "enum": ["primary", "secondary", "snooze", "dismiss", "mute"] },
          "command": { "type": "string" },
          "requiresConfirmation": { "type": "boolean", "default": false }
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope"],
      "properties": {
        "scope": { "type": "string", "enum": ["private", "party", "dm", "public"] },
        "redaction": { "type": "string", "enum": ["none", "coarse", "strict"], "default": "coarse" }
      }
    },
    "cost": { "type": "string", "enum": ["low", "med", "high"] },
    "dnd": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "flavorMode": { "type": "boolean" }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signals": { "type": "array", "items": { "type": "string" }, "maxItems": 10 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
