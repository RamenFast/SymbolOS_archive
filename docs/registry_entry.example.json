{
  "id": "symbolos.calendar",
  "displayName": "SymbolOS Calendar",
  "description": "Internal calendar MCP server providing event search and event creation tools.",
  "ownerTeam": "SymbolOS Productivity",
  "onCall": "productivity-oncall@symbolos.local",
  "environment": "prod",
  "transport": {
    "type": "https",
    "endpoint": "https://mcp-prod.symbolos.local/calendar",
    "notes": "Network-deployed service. Clients connect via the SymbolOS MCP gateway."
  },
  "auth": {
    "method": "mtls",
    "audience": "symbolos",
    "scopes": [
      "calendar.events.read",
      "calendar.events.write"
    ],
    "notes": "Service identity via mTLS; user-scoped authorization enforced server-side."
  },
  "capabilities": {
    "summary": "Search calendar events and create new events with idempotency.",
    "tools": [
      "calendar.searchEvents",
      "calendar.createEvent"
    ],
    "resources": [
      "calendar://events?from={iso}&to={iso}&limit={n}&cursor={cursor}",
      "calendar://event/{eventId}"
    ],
    "docsUrl": "docs/mcp_servers.md"
  },
  "dataClassification": "confidential",
  "rateLimits": {
    "requestsPerMinute": 600,
    "burst": 60,
    "notes": "Default limits for interactive agents."
  },
  "timeouts": {
    "defaultMs": 15000,
    "maxMs": 30000
  },
  "version": "1.0.0",
  "supportedProtocolVersions": [
    "1"
  ],
  "tags": [
    "internal",
    "calendar",
    "productivity"
  ]
}
