{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/symbolos/symbol_map.shared.schema.json",
  "title": "SymbolOS Shared Symbol Map",
  "type": "object",
  "required": ["schemaVersion", "project", "docsContext", "symbols", "indexes", "entries"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string" },
    "project": {
      "type": "object",
      "required": ["name", "entrypoints"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "entrypoints": {
          "type": "object",
          "required": ["readme", "docsIndex", "schemasIndex"],
          "additionalProperties": true,
          "properties": {
            "readme": { "type": "string", "minLength": 1 },
            "docsIndex": { "type": "string", "minLength": 1 },
            "schemasIndex": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "docsContext": {
      "type": "object",
      "required": ["notes"],
      "additionalProperties": true,
      "properties": {
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "name", "meaning", "tags"],
        "additionalProperties": true,
        "properties": {
          "symbol": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "meaning": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "indexes": {
      "type": "object",
      "required": ["docs", "schemas"],
      "additionalProperties": true,
      "properties": {
        "docs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "title", "kind"],
            "additionalProperties": true,
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "kind": { "type": "string", "minLength": 1 }
            }
          }
        },
        "schemas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "title", "kind"],
            "additionalProperties": true,
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "kind": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "path", "tags", "summary"],
        "additionalProperties": true,
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
