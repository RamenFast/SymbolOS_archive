{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symbolos.local/schemas/registry_entry.schema.json",
  "title": "SymbolOS MCP Registry Entry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^[a-z][a-z0-9_-]*\\.[a-z0-9_.-]+$",
      "description": "Stable, globally unique server id (suggestion: reverse-domain-like namespace). Example: symbolos.calendar"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "ownerTeam": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "onCall": {
      "type": "string",
      "maxLength": 500,
      "description": "How to reach the team responsible (email, pager rotation link, etc)."
    },
    "environment": {
      "type": "string",
      "enum": ["local", "dev", "stage", "prod"]
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["stdio", "http", "https", "custom"]
        },
        "endpoint": {
          "type": "string",
          "maxLength": 2000,
          "description": "If type is http/https/custom, where to connect (URL/host)."
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      },
      "required": ["type"]
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": ["none", "mtls", "oauth2", "api_key", "signed_token", "custom"]
        },
        "audience": {"type": "string", "maxLength": 200},
        "scopes": {
          "type": "array",
          "items": {"type": "string", "maxLength": 200},
          "maxItems": 200
        },
        "notes": {"type": "string", "maxLength": 2000}
      },
      "required": ["method"]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {"type": "string", "maxLength": 2000},
        "tools": {
          "type": "array",
          "items": {"type": "string", "maxLength": 200},
          "maxItems": 500,
          "description": "Optional: curated list of tool names."
        },
        "resources": {
          "type": "array",
          "items": {"type": "string", "maxLength": 2000},
          "maxItems": 500,
          "description": "Optional: curated list of resource URI templates."
        },
        "docsUrl": {"type": "string", "maxLength": 2000}
      },
      "required": ["summary"]
    },
    "dataClassification": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "rateLimits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requestsPerMinute": {"type": "integer", "minimum": 1, "maximum": 1000000},
        "burst": {"type": "integer", "minimum": 0, "maximum": 1000000},
        "notes": {"type": "string", "maxLength": 2000}
      }
    },
    "timeouts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultMs": {"type": "integer", "minimum": 1, "maximum": 600000},
        "maxMs": {"type": "integer", "minimum": 1, "maximum": 600000}
      }
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "Server version (recommend SemVer)."
    },
    "supportedProtocolVersions": {
      "type": "array",
      "items": {"type": "string", "maxLength": 50},
      "maxItems": 20
    },
    "tags": {
      "type": "array",
      "items": {"type": "string", "maxLength": 50},
      "maxItems": 50
    }
  },
  "required": [
    "id",
    "displayName",
    "ownerTeam",
    "environment",
    "transport",
    "auth",
    "capabilities",
    "dataClassification",
    "version"
  ]
}
