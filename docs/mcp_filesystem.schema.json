{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Filesystem Server — Tool Definitions",
  "description": "Schema for MCP Filesystem server tools (read, write, delete, list). All paths normalized to workspace root.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "enum": ["read_file", "write_file", "delete_file", "list_directory", "get_file_metadata"]
          },
          "description": {
            "type": "string"
          },
          "inputSchema": {
            "type": "object"
          },
          "outputSchema": {
            "type": "object",
            "description": "JSON Schema describing the tool result payload"
          },
          "requiresConfirmation": {
            "type": "boolean"
          },
          "riskLevel": {
            "type": "string",
            "enum": ["read", "write", "sensitive"]
          }
        },
        "required": ["name", "description", "riskLevel"]
      }
    }
  },
  "examples": [
    {
      "tools": [
        {
          "name": "read_file",
          "description": "Read file contents (any type; binaries returned as base64)",
          "riskLevel": "read",
          "requiresConfirmation": false,
          "inputSchema": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "File path relative to workspace root"
              },
              "encoding": {
                "type": "string",
                "enum": ["utf-8", "base64"],
                "description": "For text files, use utf-8; binaries use base64 (default: utf-8)"
              }
            },
            "required": ["path"]
          },
          "outputSchema": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "content": { "type": "string" },
              "encoding": { "type": "string", "enum": ["utf-8", "base64"] }
            },
            "required": ["content", "encoding"]
          }
        },
        {
          "name": "write_file",
          "description": "Create or update file. Validates against schema if .json/.yaml.",
          "riskLevel": "write",
          "requiresConfirmation": false,
          "inputSchema": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "File path relative to workspace root"
              },
              "content": {
                "type": "string",
                "description": "File content (text or base64 for binaries)"
              },
              "schema": {
                "type": "string",
                "description": "Path to schema file for validation (optional)"
              }
            },
            "required": ["path", "content"]
          },
          "outputSchema": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ok": { "type": "boolean" },
              "path": { "type": "string" }
            },
            "required": ["ok", "path"]
          }
        },
        {
          "name": "delete_file",
          "description": "Remove file (requires confirmation)",
          "riskLevel": "sensitive",
          "requiresConfirmation": true,
          "inputSchema": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "File path relative to workspace root"
              }
            },
            "required": ["path"]
          },
          "outputSchema": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ok": { "type": "boolean" },
              "path": { "type": "string" }
            },
            "required": ["ok", "path"]
          }
        },
        {
          "name": "list_directory",
          "description": "Enumerate directory contents",
          "riskLevel": "read",
          "requiresConfirmation": false,
          "inputSchema": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "Directory path (default: root)"
              },
              "recursive": {
                "type": "boolean",
                "description": "If true, list all subdirectories (default: false)"
              }
            }
          },
          "outputSchema": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "entries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "isDirectory": { "type": "boolean" }
                  },
                  "required": ["name", "isDirectory"]
                }
              }
            },
            "required": ["entries"]
          }
        },
        {
          "name": "get_file_metadata",
          "description": "Retrieve file size, modified time, permissions",
          "riskLevel": "read",
          "requiresConfirmation": false,
          "inputSchema": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              }
            },
            "required": ["path"]
          },
          "outputSchema": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "size": { "type": "integer" },
              "modifiedTime": { "type": "string" }
            },
            "required": ["path"]
          }
        }
      ]
    }
  ]
}
