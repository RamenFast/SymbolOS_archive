{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symbolos.local/schemas/meta_awareness_event.schema.json",
  "title": "MetaAwarenessEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "timestamp", "kind"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "kind": {
      "type": "string",
      "enum": [
        "boundary_check",
        "loop_detected",
        "scope_reduction",
        "confirmation_required",
        "dnd_suppressed"
      ]
    },
    "barriers": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "enum": ["mode", "scope", "memory", "tool", "narrative"]
      }
    },
    "summary": { "type": "string", "maxLength": 400 },
    "userFacing": { "type": "boolean", "default": false },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "description": "Redacted context for debugging; avoid sensitive payloads."
    }
  }
}
